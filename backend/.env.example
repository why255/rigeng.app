# 日耕后台 环境变量样例（复制为 .env 后按需修改，禁止把真实 .env 提交仓库）
# ⚠️ 所有 "changeme" 占位符必须替换为真实凭证

# ── 运行环境 ──
RIGENG_ENV=dev                    # dev / test / prod 三环境完全隔离

# ── 数据库 ──
# 生产：PostgreSQL（需 pgvector 扩展）
# DATABASE_URL=postgresql+psycopg2://rigeng:rigeng@localhost:5432/rigeng
# 本地快速起步 / 测试：SQLite（零依赖，默认）
DATABASE_URL=sqlite:///./rigeng_dev.db

# ── JWT 鉴权 ──
# 开发环境可用简单值；生产环境必须使用强随机字符串（生成命令：openssl rand -hex 32）
JWT_SECRET=dev-local
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080            # 7 天

# ── 试用期 ──
TRIAL_DAYS=7

# ── 携君库版权防护 ──
PUBLIC_KB_COPY_CHAR_LIMIT=500       # 携君库单次复制字符上限

# ── 搜索/RAG（S1）──
EMBEDDING_MODEL=bge-large-zh
EMBEDDING_DIM=1024
RAG_TOP_N=10
RAG_SIMILARITY_THRESHOLD=0.65

# ── 安全/加密（S3）──
ENCRYPTION_ALGO=AES-256-GCM
ENCRYPTION_ALGO_VERSION=v1
# LOCAL_ENCRYPTION_KEY=  # 64字符Hex（= 32字节密钥），生产环境必须通过环境变量注入

# ── 服务熔断/降级（P3）──
CB_FAILURE_THRESHOLD=5
CB_TIMEOUT_SECONDS=60
CB_HALF_OPEN_LIMIT=3
DOWNSTREAM_TIMEOUT_SECONDS=10

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ═══════════════════════════════════════════════
# 以下为外部服务凭证（必须替换为真实值才能用）
# ═══════════════════════════════════════════════

# ── ③ 语音/智能引擎（P1）──
# ═══ 阿里云 通义听悟 ASR（默认在线ASR — Excel #5） ═══
TINGWU_API_KEY=YOUR_TINGWU_API_KEY
TINGWU_APP_KEY=YOUR_TINGWU_APP_KEY
TINGWU_ENDPOINT=https://tingwu.cn-beijing.aliyuncs.com

# ═══ 腾讯云语音识别 ASR（保留作为备用） ═══
TENCENT_ASR_SECRET_ID=YOUR_TENCENT_SECRET_ID
TENCENT_ASR_SECRET_KEY=YOUR_TENCENT_SECRET_KEY
TENCENT_ASR_REGION=ap-guangzhou
TENCENT_ASR_ENGINE=16k_zh
TENCENT_ASR_APPID=YOUR_TENCENT_APPID

# 离线语音
ENABLE_OFFLINE_ASR=true
OFFLINE_ASR_MODEL_PATH=./models/vosk-model-small-cn-0.22

# ═══ 字节火山引擎 — 豆包 Seed 2.0 Pro（AI对话主模块 — Excel #1） ═══
VOLCANO_API_KEY=YOUR_VOLCANO_API_KEY
VOLCANO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VOLCANO_CHAT_MODEL=doubao-seed-2-0-pro
VOLCANO_MULTIMODAL_MODEL=doubao-seed-2-0-pro-260215

# ═══ 阿里云 DashScope — 通义千问 Qwen3.7-Max（HR模板 — Excel #2） ═══
DASHSCOPE_API_KEY=YOUR_DASHSCOPE_API_KEY
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_CHAT_MODEL=qwen3.7-max-preview
DASHSCOPE_TTS_MODEL=qwen-tts-hd

# ═══ 腾讯混元 Hy3（会议纪要 — Excel #3） ═══
HUNYUAN_SECRET_ID=YOUR_HUNYUAN_SECRET_ID
HUNYUAN_SECRET_KEY=YOUR_HUNYUAN_SECRET_KEY
HUNYUAN_MODEL=hy3-preview
HUNYUAN_ENDPOINT=https://api.hunyuan.cloud.tencent.com/v1

# ═══ 月之暗面 Kimi K2.5（私有知识库问答 — Excel #4） ═══
KIMI_API_KEY=YOUR_KIMI_API_KEY
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=kimi-k2.5

# ═══ DeepSeek V4-Pro（工作诊断&成长分析 — Excel #9） ═══
DEEPSEEK_API_KEY=YOUR_DEEPSEEK_API_KEY
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ═══ 智谱AI GLM-4.5（IP内容创作 — Excel #10） ═══
# 可用的模型 ID（见 docs.bigmodel.cn 模型概览）：
#   glm-4.5       — 推荐（Excel指定）
#   GLM-4.7       — 均衡全能
#   GLM-4.5-Air   — 轻量高效
ZHIPUAI_API_KEY=YOUR_ZHIPUAI_API_KEY
ZHIPUAI_MODEL=glm-4.5
ZHIPUAI_MAX_TOKENS=4096
ZHIPUAI_TEMPERATURE=0.7

# ── ④ 文件存储 ──
OBJECT_STORAGE_PROVIDER=local
UPLOAD_MAX_MB=1024
AUDIO_COMPRESS_BITRATE=64k

# ── ⑥ 消息/推送（P2）──
# 阿里云移动推送
ALIYUN_PUSH_APP_KEY=335727120
ALIYUN_PUSH_APP_SECRET=YOUR_ALIYUN_PUSH_APP_SECRET
ALIYUN_PUSH_REGION=cn-hangzhou
# 阿里云短信
ALIYUN_SMS_ACCESS_KEY_ID=YOUR_ALIYUN_ACCESS_KEY_ID
ALIYUN_SMS_ACCESS_KEY_SECRET=YOUR_ALIYUN_ACCESS_KEY_SECRET
ALIYUN_SMS_SIGN_NAME=长沙仝聚教育科技有限公司
ALIYUN_SMS_TEMPLATE_LOGIN_VERIFY=SMS_508600056
ALIYUN_SMS_TEMPLATE_ALERT=SMS_335270859
# 推送频控
CARE_PUSH_MAX_PER_WEEK=5
CARE_PUSH_WINDOW_START=9
CARE_PUSH_WINDOW_END=21
NEW_USER_QUIET_DAYS=7
SMS_ENABLED=false
