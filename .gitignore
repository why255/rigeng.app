# .gitignore for 日耕驾驶舱

# ============================================
# 项目内部 reins 配置（不进入 GitHub）
# ============================================
.harness/
.mavis/
*.local.md

# ============================================
# 桌面工具内部状态（reasonix / MiniMax 等）
# ============================================
.reasonix/
.minimax/

# ============================================
# 依赖与构建产物
# ============================================
node_modules/
dist/
build/
target/
*.exe
*.dll
*.pdb
*.so
*.dylib

# ============================================
# 本地数据与配置
# ============================================
*.db
*.sqlite
*.sqlite3
.env
.env.local
config.local.*

# ============================================
# 日志与临时
# ============================================
*.log
logs/
tmp/
temp/

# ============================================
# IDE 与系统文件
# ============================================
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ============================================
# 媒体临时文件
# ============================================
*.mp4.tmp
*.mp3.tmp
*.png.tmp
.cache/

# ============================================
# 历史遗留目录（保留在磁盘，git 不跟踪）
# ============================================
docs/            # 历史 PRD 残留，已归档到 过期版本文档/
prototype/       # 历史原型空目录，已废弃
node_modules/    # 备份（防止根 .gitignore 不生效）
